API_V1_STR=/api/v1
APP_NAME=CSI Backend
DEBUG=false
ENVIRONMENT=development
TZ=Asia/Shanghai

MARIADB_URL=mysql+aiomysql://user:password@localhost:3306/dbname

MONGODB_URL=mongodb://localhost:27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password
MONGODB_DB_NAME=csi_db

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=password
COMPONENT_LOG_RETENTION_DAYS=30
COMPONENT_LOG_DATA_STREAM=csi-component-logs
COMPONENT_HEARTBEAT_INTERVAL_SECONDS=10
COMPONENT_LEASE_SECONDS=30
COMPONENT_RUN_TIMEOUT_SECONDS=0
ACTION_TIMEOUT_CHECK_INTERVAL_SECONDS=1
ACTION_SCHEDULER_POLL_SECONDS=10
ACTION_SCHEDULER_BATCH_SIZE=100
ACTION_SCHEDULER_LOCK_SECONDS=30
ACTION_SCHEDULER_HEARTBEAT_TTL_SECONDS=30

CRAWLAB_BASE_URL=http://localhost:8080
CRAWLAB_TOKEN=your_token_here

SERVER_HOST=your_server_host
SERVER_PORT=your_server_port

RABBITMQ_HOST=host
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rabbitmq
RABBITMQ_PASSWORD=password
RABBITMQ_VHOST=/

COS_ENDPOINT=http://host:port
COS_ACCESS_KEY_ID=access_key_id
COS_SECRET_ACCESS_KEY=secret_access_key
COS_BUCKET_NAME=bucket_name
COS_REGION=us-east-1

USE_PROXY=true
OUT_SERVICE_PROXY=http://hsot:port
MAX_LOGO_SIZE=15728640

EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_MODEL_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL_API_KEY=your_api_key_here

DOCKER_HOST=
AIO_SANDBOX_IMAGE=csi-sandbox-aio
WINDOWS_SANDBOX_IMAGE=dockurr/windows:latest
WINDOWS_TEMPLATE_VOLUME=win_template_vol
SANDBOX_PORT_RANGE=16700-16799

AUTH_SECRET_KEY=please-change-auth-secret-key
AUTH_ISSUER=csi-back
AUTH_AUDIENCE=csi-user-api
COMPONENT_AUTH_AUDIENCE=csi-action-sdk
ACCESS_TOKEN_EXPIRE_MINUTES=30
COMPONENT_TOKEN_EXPIRE_MINUTES=30
COMPONENT_BOOTSTRAP_EXPIRE_SECONDS=300
AUTH_REDIS_NAMESPACE=csi:auth
LOGIN_FAILURE_THRESHOLD=5
LOGIN_FAILURE_WINDOW_SECONDS=900
LOGIN_LOCK_SECONDS=900
LOGIN_RATE_LIMIT_ACCOUNT=10
LOGIN_RATE_LIMIT_SOURCE=30
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
TEMPORARY_ACCOUNT_MAX_DAYS=90
INIT_SYSTEM_USERNAME=admin
INIT_SYSTEM_PASSWORD=admin123456
INIT_SYSTEM_DISPLAY_NAME=管理员
INIT_SYSTEM_EMAIL=admin@example.com
INIT_SYSTEM_GROUP_NAME=admin

# 管理员页面写入的当前/目标配置与 MongoDB 审计 outbox；完整版本历史保存在 MongoDB
# Docker Compose 会覆盖为 /app/data/system-config.json
CSI_SYSTEM_CONFIG_FILE=./data/system-config.json
