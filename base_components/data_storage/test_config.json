{
    "meta": {
        "node_id": "snapshot_article",
        "action_id": "snapshot_article"
    },
    "config": {
        "target": "elasticsearch",
        "target_name": "article",
        "batch_size": 5000,
        "storage_filter": false
    },
    "inputs": {
        "conditions": {
            "$and": [
                {
                    "field": "snapshot",
                    "op": "not_exists"
                }
            ]
        }
    },
    "outputs": {
        "data_out": {
            "type": "reference",
            "value": [
                "snapshot"
            ]
        }
    }
}