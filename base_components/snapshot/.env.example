# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# COS (对象存储) 配置 - 用于媒体资源本地化
# MinIO 或其他 S3 兼容服务的配置
COS_ENDPOINT=http://localhost:9000
COS_ACCESS_KEY=your_access_key
COS_SECRET_KEY=your_secret_key
COS_BUCKET=media-bucket
COS_REGION=us-east-1
# 可选：自定义访问域名，如果不设置则使用 endpoint/bucket/filename 格式
COS_BASE_URL=https://cdn.example.com

# 抓取/下载代理（可选）
# Playwright 抓取网页时使用；未设置则不使用代理
DOWNLOAD_PROXY=http://localhost:7890
